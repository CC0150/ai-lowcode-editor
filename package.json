{
  "name": "ai-lowcode-editor",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "install-all": "npm install && npm install -w client && npm install -w server",
    "start:client": "npm run dev -w client",
    "start:server": "npm run dev -w server",
    "dev": "concurrently \"npm run start:client\" \"npm run start:server\"",
    "build": "concurrently \"npm run build -w client\" \"npm run build -w server\"",
    "build:client": "npm run build -w client",
    "build:server": "npm run build -w server"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}